extends ../layouts/navigation
block styles
    link(rel="stylesheet", href="../css/training.css")

block content
        main
            div.grid
                if workouts.length > 0
                    each workout in workouts
                        article.card.training-item
                            header.card__header
                                h1.training__exerciseTitle #{workout.exerciseTitle}
                            div.card__image
                                img(src="https://cdn.pixabay.com/photo/2016/03/31/20/51/book-1296045_960_720.png", alt="Training")
                            div.card__content
                                h2.training__reps Reps: 12
                                h2.training__sets Sets: 3
                                h2.training__muscleGroup Muscle group: Back
                                p.training__note String....
                            div.card__actions
                                button.btn Add training
                else
                    h1 No trainings

