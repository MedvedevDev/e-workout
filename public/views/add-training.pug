extends layouts/main-layout.pug

block styles
    link(rel="stylesheet", href="../css/training.css")
    link(rel="stylesheet", href="../css/forms.css")

block content
    main
        form.training-form(action="/admin/add-training", method="POST")
            div.form-control
                label(for="title") Exercise title
                input(type="text", name="title")#title
            button.btn(type="submit") Add Training

