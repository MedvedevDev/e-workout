<!DOCTYPE html>
html(lang="en")
    head
        meta(charset="UTF-8")
        meta(name="viewport", content="width=device-width, initial-scale=1.0")
        meta(http-equiv="X-UA-Compatible", content="ie=edge")
        title #{docTitle}
        link(rel="stylesheet", href="../css/main.css")
        link(rel="stylesheet", href="../css/training.css")
    body
        header.main-header
            nav.main-header__nav
                ul.main-header__item-list
                    li.main-header__item
                        a.active(href="/") Trainings
                    li.main-header__item
                        a(href="/admin/add-training") Add Training
        main
            div.grid
                if trainings.length > 0
                    each training in trainings
                        article.card.training-item
                            header.card__header
                                h1.training__exerciseTitle #{training.exerciseTitle}
                            div.card__image
                                img(src="https://cdn.pixabay.com/photo/2016/03/31/20/51/book-1296045_960_720.png", alt="Training")
                            div.card__content
                                h2.training__reps 12
                                h2.training__sets 3
                                h2.training__muscleGroup Back
                                p.training__note .....String....
                            div.card__actions
                                button.btn Add training
                else
                    h1 No trainings

